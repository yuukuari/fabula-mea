# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Utilisé côté serveur UNIQUEMENT (Vercel Functions) — jamais exposé au navigateur.
# Trouvez ces valeurs dans : https://console.upstash.com → votre base → REST API

UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxx

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens d'authentification (30 jours de validité).
# Générez une clé forte : openssl rand -base64 32

JWT_SECRET=changez-moi-avec-une-cle-aleatoire-forte

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
# Paire de clés VAPID pour les notifications push du navigateur.
# Générez-les avec : npx web-push generate-vapid-keys
# La clé publique est utilisée côté client ET serveur.
# La clé privée est utilisée côté serveur UNIQUEMENT.

VITE_VAPID_PUBLIC_KEY=BPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Spotify ─────────────────────────────────────────────────────────────────
VITE_SPOTIFY_CLIENT_ID="spotify-client-id"