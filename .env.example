# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Utilisé côté serveur UNIQUEMENT (Vercel Functions) — jamais exposé au navigateur.
# Trouvez ces valeurs dans : https://console.upstash.com → votre base → REST API

UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxx

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens d'authentification (30 jours de validité).
# Générez une clé forte : openssl rand -base64 32

JWT_SECRET=changez-moi-avec-une-cle-aleatoire-forte
